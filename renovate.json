{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>immich-app/.github:renovate-config"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "/helm/"
      ],
      "groupName": "helm"
    },
    {
      "matchDepNames": [
        "ctlptl",
        "kind",
        "tilt"
      ],
      "groupName": "testing dependencies"
    }
  ]
}
